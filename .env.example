# PayCore — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_strong_password

# HashiCorp Vault
VAULT_TOKEN=change_me_root_token
# In production use VAULT_ROLE_ID + VAULT_SECRET_ID (AppRole auth)
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# Grafana
GRAFANA_PASSWORD=change_me_admin_password

# PAN encryption pepper (32 bytes, hex-encoded, store in Vault in prod)
PAN_PEPPER=change_me_32_bytes_hex_encoded_pepper_here

# Kafka SASL (production)
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# mTLS certificates paths (production)
GATEWAY_TLS_CERT_PATH=/etc/paycore/tls/gateway.crt
GATEWAY_TLS_KEY_PATH=/etc/paycore/tls/gateway.key
GATEWAY_TLS_CA_PATH=/etc/paycore/tls/ca.crt

# OpenTelemetry
OTEL_SERVICE_NAME=paycore
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# =============================================================================
# Acquirer Routing (for ACQUIRER mode — no payment license needed)
# =============================================================================

# Processing mode: INTERNAL (sandbox ledger) or ACQUIRER (real money via acquirer)
PAYCORE_PROCESSING_MODE=INTERNAL

# YooKassa — https://yookassa.ru/developers
# Sandbox credentials: shopId=100500, secretKey=test_...
# Get your own at: https://yookassa.ru/my/shop-settings
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=100500
YOOKASSA_SECRET_KEY=test_your_secret_key_here
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3

# Tinkoff Kassa — https://www.tinkoff.ru/kassa/develop/api/
# Sandbox: TerminalKey=TinkoffBankTest, SecretKey=TinkoffBankTest
# Get your own at: https://business.tinkoff.ru/openbusiness/form/internet-acquiring/
TINKOFF_ENABLED=false
TINKOFF_TERMINAL_KEY=TinkoffBankTest
TINKOFF_SECRET_KEY=TinkoffBankTest
TINKOFF_BASE_URL=https://securepay.tinkoff.ru/v2
